---
import { SITE } from '../data/site.js';
---
<footer class="site-footer">
  <div class="container text-center">
    <h2 class="site-footer__cta">Book your stay.</h2>
    <p class="site-footer__contact">
      {SITE.address}<br />
      <a href={SITE.phoneHref}>{SITE.phone}</a> &nbsp;·&nbsp;
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a><br />
      <a href={SITE.instagram}>{SITE.instagramHandle}</a>
    </p>
    <p class="site-footer__copy">&copy; 2026 {SITE.brand}</p>
  </div>
</footer>

<style>
  .site-footer { background: var(--color-dark); color: #dfe4e3; padding-block: clamp(2.5rem, 6vw, 4rem); }
  .site-footer__cta { color: #fff; font-family: var(--font-display); font-weight: 300; letter-spacing: 0.04em; }
  .site-footer__contact { margin: 1rem 0; }
  .site-footer a { color: #dfe4e3; text-decoration: none; }
  .site-footer a:hover { color: #fff; }
  .site-footer__copy { font-size: 0.72rem; letter-spacing: 0.16em; text-transform: uppercase; color: #9aa3a1; margin-top: 1.8rem; font-family: var(--font-display); }
</style>
