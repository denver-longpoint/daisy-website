---
import { SITE, NAV } from '../data/site.js';
const path = Astro.url.pathname;
---
<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href="/">{SITE.brand}</a>

    <nav class="nav" aria-label="Primary">
      {NAV.map((item) => (
        item.children ? (
          <div class="nav__group">
            <a href={item.href} class="nav__link">{item.label}</a>
            <div class="nav__menu">
              {item.children.map((c) => <a href={c.href}>{c.label}</a>)}
            </div>
          </div>
        ) : (
          <a href={item.href} class="nav__link">{item.label}</a>
        )
      ))}
      <a href="/contact" class="nav__contact">Contact</a>
    </nav>
  </div>
</header>

<style>
  .site-header { background: var(--color-dark); }
  .site-header__inner {
    max-width: 1280px; margin-inline: auto;
    padding: 1.6rem clamp(1.25rem, 4vw, 2.5rem);
    display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap;
  }
  .brand {
    color: #fff; text-decoration: none;
    font-family: var(--font-display); font-weight: 300;
    text-transform: uppercase; letter-spacing: 0.14em;
    font-size: clamp(0.8rem, 1.4vw, 1.05rem);
  }
  .nav { display: flex; align-items: center; gap: clamp(1rem, 2.5vw, 2.4rem); flex-wrap: wrap; }
  .nav__link, .nav__menu a {
    color: #fff; text-decoration: none;
    font-family: var(--font-display); font-weight: 300;
    text-transform: uppercase; letter-spacing: 0.18em; font-size: 0.82rem;
  }
  .nav__link:hover { color: #cdd6d4; }
  .nav__group { position: relative; }
  .nav__menu {
    position: absolute; top: 100%; left: 50%; transform: translateX(-50%);
    background: var(--color-dark); padding: 0.5rem 0; min-width: 210px;
    display: none; flex-direction: column; z-index: 20;
    box-shadow: 0 8px 24px rgba(0,0,0,0.25);
  }
  .nav__group:hover .nav__menu, .nav__group:focus-within .nav__menu { display: flex; }
  .nav__menu a { padding: 0.6rem 1.4rem; letter-spacing: 0.12em; }
  .nav__menu a:hover { background: var(--color-dark-hover); }
  .nav__contact {
    color: #fff; text-decoration: none;
    font-family: var(--font-display); font-weight: 300;
    text-transform: uppercase; letter-spacing: 0.18em; font-size: 0.82rem;
    border: 1px solid rgba(255,255,255,0.4); padding: 0.7rem 1.4rem;
    background: rgba(255,255,255,0.06);
  }
  .nav__contact:hover { background: rgba(255,255,255,0.14); }
  @media (max-width: 760px) {
    .site-header__inner { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .nav { gap: 1rem 1.4rem; }
    .nav__menu { position: static; transform: none; display: flex; box-shadow: none; padding: 0.25rem 0 0.25rem 1rem; min-width: 0; }
  }
</style>
