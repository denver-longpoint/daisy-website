---
import Base from '../layouts/Base.astro';
const title = 'Photos & Video — Daisy Cottage | Cape Cod Vacation Rental';
const description = 'Photos and video from Daisy Cottage on Beach Point in North Truro — sunsets, storms over Cape Cod Bay, and our full gallery.';
const sunset = ["Cape Cod Sunset.png", "Cape Cod Sunsets.png", "Days Cottages Sunset.png", "North Truro Beach Sunset.png", "North Truro Sunet.png", "Sunset Over Cape Cod.png", "Sunset OVer Provincetown.png", "Summer Evening Daisy Cottage.png", "Seagull flying by the camera.jpg"];
const storms = ["Stormy Cape Cod.png", "Lightning over Cape Cod.png"];
const gallery = ["Aerial View of Beach Point.JPG", "Beach Point Beer Bottle.jpg", "Cape Cod in the Fall.jpg", "Daisy Cottage 1930s.jpg", "IMG_0888 copy.JPG", "IMG_1070 copy.JPG", "IMG_1079 copy.JPG", "IMG_4700.jpg", "IMG_4701.jpg", "IMG_5009.jpg", "IMG_5029.jpg", "IMG_5031.jpg", "IMG_5060.jpg", "IMG_5081.jpg", "IMG_5412.JPG", "Provincetown Harbor.png", "aerial-view-of-cape-cod.jpeg", "banner-plane-over-truro.jpeg", "beach-at-days-cottages.jpeg", "beach-fire-at-days-cottages.jpeg", "beach-rocks-daisy-cottage.jpeg", "beachfront-days-cottages.jpeg", "beautiful-provincetown-sunset.png", "cape-air-over-race-point-road.jpeg", "cape-cod-family-vacation-rental.jpeg", "cape-cod-winter-getaway.jpeg", "clothesline-daisy-cottage.jpeg", "cold-night-at-daisy-cottage.jpeg", "commercial-street-from-pilgrim-monument.jpeg", "daisy-cottage-at-night.jpeg", "daisy-cottage-ceiling-renovation.jpeg", "daisy-cottage-renovation.jpeg", "days-cottages-historic-house.jpeg", "days-cottages-rentals.jpeg", "early-morning-light-days-cottages.jpeg", "fall-beach-rental-truro-massachusetts.png", "fireplace-inside-daisy-cottage.jpeg", "fishing-boat-daisy-cottage.jpeg", "fresh-picked-cranberries.jpeg", "hms-somerset-shipwreck.jpeg", "horseshoe-crab-days-cottages.jpeg", "icy-shore-road-truro.jpeg", "identical-cottages-truro.jpg", "kayaking-at-days-cottages.jpg", "kayaks-provincetown-bay.jpeg", "lewis-brothers-ice-cream.jpeg", "lobster-pot-christmas-tree-provincetown.jpeg", "lobster-trap-christmas-tree.jpeg", "nighttime-photography-days-cottages.jpeg", "off-season-cape-cod-rental.png", "old-boat-daisy-cottage.jpg", "old-bottle-found-on-beach.jpeg", "old-colony-tap-provincetown.jpeg", "pigeons-on-macmillan-wharf.jpeg", "pilgrim-monument-provincetown.jpg", "portuguese-dancers-commercial-street.jpeg", "provincetown-town-hall.jpeg", "residing-project-daisy-cottage Large.jpeg", "route-6a-sign.jpeg", "sailboat-on-beach-point.jpg", "sailing-at-days-cottages.jpg", "salty-market-shore-road.jpeg", "scuba-diving-truro.jpg", "seagull-at-macmillan-wharf.jpg", "seagull-beach-point-ma.jpeg", "snow-on-beach-point.jpeg", "snowman-at-days-cottages.jpeg", "snowy-cottage.jpeg", "stormy-skies-at-beach-point.jpeg", "summer-sailing-cape-cod.jpeg", "summer-thunderstorm-days-cottage.jpeg", "sunset-provincetown-harbor.jpeg", "the-penny-patch-provincetown.jpeg", "thunderstorm-over-provincetown.jpeg", "tree-house-brewery-glass.jpeg", "walking-commercial-street-provincetown.jpeg", "whale-watching-in-provincetown.jpeg", "windy-at-provincetown-harbor.jpg", "writers-retreat-cape-cod-ma.jpeg"];
const videos = [
  { id: 'TvCIajSjrwQ', t: 'Provincetown Thunderstorm Timelapse' },
  { id: 'jxbFy6Azn90', t: 'Lightning Storm over Provincetown' },
  { id: 'gHjzwAmh0BA', t: 'Summer Storm over Cape Cod Bay' },
];
const alt = (f) => f.replace(/\.[^.]+$/, '').replace(/[-_]/g, ' ');
---
<Base title={title} description={description} image="/images/beautiful-provincetown-sunset.png">
  <section class="section">
    <div class="container">
      <h1>Photos &amp; Video</h1>
      <p>A collection of photos and video from Daisy Cottage and Beach Point &mdash; sunsets over Provincetown Harbor, storms rolling across Cape Cod Bay, and everyday moments at the cottage. Tap any photo to view it full size.</p>
    </div>

    <div class="container"><h2>Daisy Cottage Sunset Collection</h2></div>
    <div class="container tiles">
      {sunset.map((f) => <a href={`/images/${f}`} target="_blank" rel="noopener"><img src={`/images/${f}`} alt={alt(f)} loading="lazy" /></a>)}
    </div>

    <div class="container"><h2 class="mt">Storms over the bay</h2></div>
    <div class="container tiles">
      {storms.map((f) => <a href={`/images/${f}`} target="_blank" rel="noopener"><img src={`/images/${f}`} alt={alt(f)} loading="lazy" /></a>)}
    </div>
    <div class="container video-grid">
      {videos.map((v) => <div class="vid"><iframe src={`https://www.youtube.com/embed/${v.id}`} title={v.t} frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen loading="lazy"></iframe></div>)}
    </div>

    <div class="container"><h2 class="mt">Photo Gallery</h2></div>
    <div class="container tiles">
      {gallery.map((f) => <a href={`/images/${f}`} target="_blank" rel="noopener"><img src={`/images/${f}`} alt={alt(f)} loading="lazy" /></a>)}
    </div>
  </section>
</Base>

<style>
  h2.mt { margin-top: 3rem; }
  .tiles { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 0.8rem; margin-top: 1.25rem; }
  .tiles a { display: block; }
  .tiles img { width: 100%; aspect-ratio: 1 / 1; object-fit: cover; display: block; }
  .video-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; margin-top: 1.25rem; }
  .video-grid .vid { aspect-ratio: 16 / 9; }
  .video-grid iframe { width: 100%; height: 100%; border: 0; display: block; }
  @media (max-width: 560px) { .tiles { grid-template-columns: 1fr 1fr; } }
</style>
