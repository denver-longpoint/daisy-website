---
import { SITE, NAV } from '../data/site.js';
---
<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href="/">{SITE.brand}</a>
    <input type="checkbox" id="navtoggle" class="navtoggle" />
    <label for="navtoggle" class="hamburger" aria-label="Toggle menu"><span></span><span></span><span></span></label>
    <nav class="nav" aria-label="Primary">
      {NAV.map((item) => (
        item.children ? (
          <div class="nav__group">
            <a href={item.href} class="nav__link">{item.label}</a>
            <div class="nav__menu">
              {item.children.map((c) => <a href={c.href}>{c.label}</a>)}
            </div>
          </div>
        ) : (
          <a href={item.href} class="nav__link">{item.label}</a>
        )
      ))}
      <a href="/contact" class="nav__contact">Contact</a>
    </nav>
  </div>
</header>

<style>
  .site-header { background: var(--color-dark); }
  .site-header__inner {
    max-width: 1280px; margin-inline: auto;
    padding: 1.6rem clamp(1.25rem, 4vw, 2.5rem);
    display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap;
  }
  .brand {
    color: #fff; text-decoration: none;
    font-family: var(--font-display); font-weight: 300;
    text-transform: uppercase; letter-spacing: 0.14em;
    font-size: clamp(0.8rem, 1.4vw, 1.05rem);
  }
  .navtoggle { display: none; }
  .hamburger { display: none; }

  .nav { display: flex; align-items: center; gap: clamp(1rem, 2.5vw, 2.4rem); }
  .nav__link, .nav__menu a {
    color: #fff; text-decoration: none;
    font-family: var(--font-display); font-weight: 300;
    text-transform: uppercase; letter-spacing: 0.18em; font-size: 0.82rem;
  }
  .nav__link:hover { color: #cdd6d4; }
  .nav__group { position: relative; }
  .nav__menu {
    position: absolute; top: 100%; left: 50%; transform: translateX(-50%);
    background: var(--color-dark); padding: 0.5rem 0; min-width: 210px;
    display: none; flex-direction: column; z-index: 20;
    box-shadow: 0 8px 24px rgba(0,0,0,0.25);
  }
  .nav__group:hover .nav__menu, .nav__group:focus-within .nav__menu { display: flex; }
  .nav__menu a { padding: 0.6rem 1.4rem; letter-spacing: 0.12em; }
  .nav__menu a:hover { background: var(--color-dark-hover); }
  .nav__contact {
    color: #fff; text-decoration: none;
    font-family: var(--font-display); font-weight: 300;
    text-transform: uppercase; letter-spacing: 0.18em; font-size: 0.82rem;
    border: 1px solid rgba(255,255,255,0.4); padding: 0.7rem 1.4rem;
    background: rgba(255,255,255,0.06);
  }
  .nav__contact:hover { background: rgba(255,255,255,0.14); }

  @media (max-width: 820px) {
    .hamburger {
      display: flex; flex-direction: column; justify-content: center; gap: 6px;
      width: 34px; height: 30px; cursor: pointer;
    }
    .hamburger span { display: block; height: 2px; background: #fff; width: 100%; transition: 0.2s; }
    .navtoggle:checked ~ .hamburger span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
    .navtoggle:checked ~ .hamburger span:nth-child(2) { opacity: 0; }
    .navtoggle:checked ~ .hamburger span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }
    .nav {
      display: none; flex-basis: 100%; flex-direction: column; align-items: flex-start;
      gap: 0.2rem; margin-top: 1rem; order: 3;
    }
    .navtoggle:checked ~ .nav { display: flex; }
    .nav__link, .nav__contact { padding: 0.75rem 0; font-size: 1rem; }
    .nav__group { width: 100%; }
    .nav__menu {
      position: static; transform: none; display: flex; box-shadow: none;
      padding: 0 0 0.5rem 1.2rem; min-width: 0; background: transparent;
    }
    .nav__menu a { padding: 0.5rem 0; font-size: 0.95rem; }
    .nav__contact { border: 0; background: transparent; padding: 0.75rem 0; }
  }
</style>
