---
import Base from '../layouts/Base.astro';
import { SITE } from '../data/site.js';
const title = 'Contact the owners of Daisy Cottage — Daisy Cottage | Cape Cod Vacation Rental';
const description = "If you're interested in renting a beach cottage in Truro, MA, get in touch with us as soon as possible.";
---
<Base title={title} description={description}>
  <section class="section">
    <div class="container contact-grid">
      <div class="contact-info">
        <h1>Daisy Cottage</h1>
        <p>If you&rsquo;re interested in renting the cottage, we can be reached by any of the following methods:</p>
        <p class="contact-methods">
          <a href={SITE.phoneHref}>(508) 364-5530</a><br />
          woodendllc (at) gmail.com
        </p>
        <p>If you're interested in reserving the cottage, please fill out the form and we'll be in touch.</p>
        <figure class="histnote">
          <img src="/images/cape-cod-family-vacation-rental.jpeg" alt="Daisy Cottage on Beach Point, Truro" loading="lazy" />
          <figcaption>Since the early 1930s, the Days&rsquo; Cottages have been owned and managed by the Days family. In 2016, the family sold 20 of the cottages.</figcaption>
        </figure>
        <p class="social">
          <a href={SITE.instagram} aria-label="Instagram" target="_blank" rel="noopener">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.2c3.2 0 3.6 0 4.9.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.86s0 3.6-.07 4.86c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.86.07s-3.6 0-4.86-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.21 15.6 2.2 15.2 2.2 12s0-3.6.07-4.86c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.4 2.21 8.8 2.2 12 2.2z M12 7.06A4.94 4.94 0 1 0 12 16.94 4.94 4.94 0 0 0 12 7.06zm0 8.14A3.2 3.2 0 1 1 12 8.8a3.2 3.2 0 0 1 0 6.4zm6.28-8.34a1.15 1.15 0 1 1-2.3 0 1.15 1.15 0 0 1 2.3 0z"/></svg>
          </a>
        </p>
      </div>

      <div class="contact-form-wrap">
        <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="cform2">
          <input type="hidden" name="form-name" value="contact" />
          <p class="cform2__hp"><label>Skip: <input name="bot-field" /></label></p>

          <label class="fld">
            <span class="fld__label">Interest <em>(required)</em></span>
            <select name="Interest" required>
              <option value="">Select an option</option>
              <option>Weekly summer rental</option>
              <option>Off-season / monthly rental</option>
              <option>General question</option>
            </select>
          </label>

          <fieldset class="fld">
            <span class="fld__label">Name</span>
            <div class="two">
              <label><span class="sub">First Name <em>(required)</em></span><input type="text" name="First Name" required /></label>
              <label><span class="sub">Last Name <em>(required)</em></span><input type="text" name="Last Name" required /></label>
            </div>
          </fieldset>

          <label class="fld"><span class="fld__label">Email Address <em>(required)</em></span><input type="email" name="Email" required /></label>
          <label class="fld"><span class="fld__label">Phone Number</span><input type="tel" name="Phone" /></label>
          <label class="fld"><span class="fld__label">Message</span><textarea name="Message" rows="5"></textarea></label>

          <fieldset class="fld">
            <span class="fld__label">Address</span>
            <label><span class="sub">Country</span>
              <select name="Country"><option>United States</option><option>Canada</option><option>Other</option></select>
            </label>
            <label><span class="sub">Address Line 1 <em>(required)</em></span><input type="text" name="Address Line 1" required /></label>
            <label><span class="sub">Address Line 2</span><input type="text" name="Address Line 2" /></label>
            <div class="two">
              <label><span class="sub">City</span><input type="text" name="City" /></label>
              <label><span class="sub">State/Province</span><input type="text" name="State" /></label>
            </div>
            <label><span class="sub">Zip/Postal Code</span><input type="text" name="Zip" /></label>
          </fieldset>

          <button type="submit" class="btn">Send</button>
        </form>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1.25fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
  .contact-info h1 { margin-bottom: 1.2rem; }
  .contact-methods { text-align: center; font-weight: 700; margin: 1.5rem 0; }
  .contact-methods a { text-decoration: none; }
  .histnote { margin: 2rem 0 1rem; }
  .histnote img { width: 100%; }
  .histnote figcaption { color: var(--color-muted); font-size: 0.9rem; margin-top: 0.6rem; }
  .social a { color: var(--color-dark); display: inline-block; }

  .cform2 label { display: block; }
  .fld { border: 0; padding: 0; margin: 0 0 1.4rem; }
  .fld__label { display: block; font-size: 1.05rem; margin-bottom: 0.4rem; }
  .fld__label em, .sub em { font-style: normal; color: var(--color-muted); font-size: 0.85rem; }
  .sub { display: block; font-size: 0.85rem; color: var(--color-muted); margin: 0.6rem 0 0.3rem; }
  .cform2 input, .cform2 select, .cform2 textarea {
    width: 100%; padding: 0.85rem 1rem; border: 1px solid var(--color-line);
    font-family: var(--font-body); font-size: 1rem; background: #fbfbfa;
  }
  .cform2 textarea { resize: vertical; }
  .two { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .cform2__hp { display: none; }
  .btn { border: 0; cursor: pointer; margin-top: 0.5rem; }
  @media (max-width: 820px) {
    .contact-grid { grid-template-columns: 1fr; }
    .two { grid-template-columns: 1fr; }
  }
</style>
